# EmailJS Configuration (Optional - if you want to send emails)
# Sign up at https://www.emailjs.com/ to get these credentials.
# Create a service (e.g., Gmail) and a template.

# Your EmailJS Service ID
NEXT_PUBLIC_EMAILJS_SERVICE_ID="YOUR_EMAILJS_SERVICE_ID"

# Your EmailJS Template ID
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID="YOUR_EMAILJS_TEMPLATE_ID"

# Your EmailJS Public Key (User ID)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY="YOUR_EMAILJS_PUBLIC_KEY"

# Genkit/Google AI (if applicable, usually handled by framework)
# GOOGLE_API_KEY="YOUR_GOOGLE_API_KEY"
